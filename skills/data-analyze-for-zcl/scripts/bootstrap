#!/usr/bin/env bash
set -euo pipefail

skill_dir="$(cd "$(dirname "$0")/.." && pwd)"
runtime_dir="$skill_dir/assets/xhs-ca"
source "$skill_dir/scripts/bootstrap_python.sh"

if ! python_launcher="$(select_xhs_ca_python)"; then
  cat >&2 <<'EOF'
data-analyze-for-zcl runtime is not ready: Python 3.11+ was not found.

Copy the whole command block below into macOS Terminal. After it finishes, return to Codex and rerun the analysis.

```bash
set -e
echo "Install Python 3.11 or 3.12, then rerun ~/.agents/skills/data-analyze-for-zcl/scripts/bootstrap."
echo "If Python is already installed outside PATH, rerun with: XHS_CA_PYTHON=/path/to/python3.12 ~/.agents/skills/data-analyze-for-zcl/scripts/bootstrap"
exit 1
```
EOF
  exit 1
fi

XHS_CA_PYTHON="$python_launcher" exec "$python_launcher" "$skill_dir/scripts/bootstrap_runtime.py" \
  --runtime-dir "$runtime_dir" \
  --skill-dir "$skill_dir" \
  --doctor-root "$runtime_dir"
