#!/usr/bin/env bash
set -euo pipefail

skill_dir="$(cd "$(dirname "$0")/.." && pwd)"
repo_root="$(cd "$skill_dir/../.." && pwd)"
runtime_dir="$skill_dir/assets/xhs-ca"

# ─── Safety guard 1: verify we are inside the correct git repository ───
actual_root="$(git -C "$repo_root" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ "$actual_root" != "$repo_root" ]]; then
  echo "ERROR: git rev-parse --show-toplevel ($actual_root) does not match expected repo root ($repo_root)." >&2
  echo "       Run this script from within the xiaohongshu-ceramics-analytics repository." >&2
  exit 1
fi

# ─── Safety guard 2: verify pyproject.toml declares the expected package ───
if ! grep -q 'name = "xiaohongshu-ceramics-analytics"' "$repo_root/pyproject.toml"; then
  echo "ERROR: $repo_root/pyproject.toml does not contain 'name = \"xiaohongshu-ceramics-analytics\"'." >&2
  echo "       This script must run inside the xiaohongshu-ceramics-analytics project." >&2
  exit 1
fi

# ─── Sync canonical sources into the skill bundle mirror ───
mkdir -p "$runtime_dir"
rsync -a --delete \
  "$repo_root/pyproject.toml" \
  "$repo_root/xhs_ceramics_analytics" \
  "$repo_root/references" \
  "$repo_root/task_templates" \
  "$repo_root/tests" \
  "$runtime_dir/"

cp "$repo_root/scripts/bootstrap_runtime.py" "$skill_dir/scripts/bootstrap_runtime.py"
cp "$repo_root/scripts/bootstrap_python.sh" "$skill_dir/scripts/bootstrap_python.sh"

find "$runtime_dir" -type d -name "__pycache__" -prune -exec rm -rf {} +
find "$runtime_dir" -type d -name ".pytest_cache" -prune -exec rm -rf {} +
find "$runtime_dir" -type d -name ".ruff_cache" -prune -exec rm -rf {} +

# ─── Prepend "DO NOT EDIT" banners to mirrored files ───
MD_BANNER="<!-- DO NOT EDIT — generated by scripts/sync-runtime. Edit the top-level source. -->"
PY_INIT_BANNER="# DO NOT EDIT — generated by scripts/sync-runtime. Edit the top-level source."

banner_dirs=(
  "$runtime_dir/references"
  "$runtime_dir/task_templates"
  "$runtime_dir/xhs_ceramics_analytics"
)

for dir in "${banner_dirs[@]}"; do
  [[ -d "$dir" ]] || continue

  # Markdown files: prepend HTML comment banner
  while IFS= read -r -d '' mdfile; do
    if ! head -1 "$mdfile" | grep -qF "DO NOT EDIT"; then
      tmp="$(mktemp)"
      printf '%s\n\n' "$MD_BANNER" | cat - "$mdfile" > "$tmp"
      mv "$tmp" "$mdfile"
    fi
  done < <(find "$dir" -type f -name "*.md" -print0)

  # Python __init__.py files only: prepend comment banner
  while IFS= read -r -d '' initfile; do
    if ! head -1 "$initfile" | grep -qF "DO NOT EDIT"; then
      tmp="$(mktemp)"
      printf '%s\n' "$PY_INIT_BANNER" | cat - "$initfile" > "$tmp"
      mv "$tmp" "$initfile"
    fi
  done < <(find "$dir" -type f -name "__init__.py" -print0)
done

# ─── Per-directory summary ───
echo "sync-runtime: sync complete."
for dir in "${banner_dirs[@]}"; do
  if [[ -d "$dir" ]]; then
    count="$(find "$dir" -type f | wc -l | tr -d ' ')"
    echo "  $(basename "$dir")/: $count files"
  fi
done
