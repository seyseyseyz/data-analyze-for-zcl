#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
python_launcher=""

for candidate in python3.12 python3.11 python3; do
  if command -v "$candidate" >/dev/null 2>&1; then
    python_launcher="$(command -v "$candidate")"
    break
  fi
done

if [[ -z "$python_launcher" ]]; then
  cat >&2 <<'EOF'
data-analyze-for-zcl runtime is not ready: Python 3.11+ was not found.

Copy the whole command block below into macOS Terminal. After it finishes, return to Codex and rerun the analysis.

```bash
set -e
echo "Install Python 3.11 or 3.12, then rerun ./scripts/bootstrap from the project root."
exit 1
```
EOF
  exit 1
fi

exec "$python_launcher" "$repo_root/scripts/bootstrap_runtime.py" \
  --runtime-dir "$repo_root" \
  --skill-dir "$repo_root" \
  --doctor-root "$repo_root"
