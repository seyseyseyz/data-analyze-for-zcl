#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
repo_root="$(cd "$(dirname "$0")/.." && pwd)"
source "$script_dir/bootstrap_python.sh"

if ! python_launcher="$(select_xhs_ca_python)"; then
  cat >&2 <<'EOF'
data-analyze-for-zcl runtime is not ready: Python 3.11+ was not found.

Copy the whole command block below into macOS Terminal. After it finishes, return to Codex and rerun the analysis.

```bash
set -e
echo "Install Python 3.11 or 3.12, then rerun ./scripts/bootstrap from the project root."
echo "If Python is already installed outside PATH, rerun with: XHS_CA_PYTHON=/path/to/python3.12 ./scripts/bootstrap"
exit 1
```
EOF
  exit 1
fi

XHS_CA_PYTHON="$python_launcher" exec "$python_launcher" "$repo_root/scripts/bootstrap_runtime.py" \
  --runtime-dir "$repo_root" \
  --skill-dir "$repo_root" \
  --doctor-root "$repo_root"
